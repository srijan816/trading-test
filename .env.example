# --- API Keys ---
OPENROUTER_API_KEY=your_openrouter_api_key
MINIMAX_API_KEY=your_minimax_api_key
NVIDIA_API_KEY=your_nvidia_api_key
POLYMARKET_API_KEY=your_polymarket_api_key
POLYMARKET_SECRET=your_polymarket_secret
GEMINI_API_KEY=your_gemini_api_key

# --- Nexus ---
NEXUS_PORT=3001
NEXUS_URL=http://localhost:3001
NEXUS_API_KEY=your_nexus_api_key
NEXUS_DEFAULT_MODEL=stepfun/step-3.5-flash:free
NEXUS_DECOMPOSITION_MODEL=stepfun/step-3.5-flash:free
NEXUS_SEARCH_MODEL=stepfun/step-3.5-flash:free
NEXUS_SYNTHESIS_MODEL=minimax/minimax-m2.7

# --- Services ---
SEARXNG_URL=http://localhost:8081
CRAWL4AI_URL=http://localhost:11235

# --- Arena Trading ---
ARENA_LIVE_TRADING=false
SPREAD_FILTER_MIN_NET_EDGE_CENTS=2
SPREAD_FILTER_MAX_SPREAD_CENTS=8
SPREAD_FILTER_MIN_VOLUME=50

# --- Risk Management ---
# Max dollar amount for a single trade (central Kelly enforcement hard cap)
RISK_MAX_SINGLE_TRADE_SIZE=50
# Kelly fraction multiplier applied in compute_position_size (0.5 = half-kelly if arena.toml uses 0.25)
RISK_KELLY_FRACTION_MULTIPLIER=0.5
# Minimum trade size in dollars
RISK_MIN_TRADE_SIZE=5
# Price movement threshold (cents) below which re-entry on same market is blocked
RISK_REENTRY_PRICE_DELTA_CENTS=5
# Maximum exposure allowed per market across all open positions
RISK_MAX_EXPOSURE_PER_MARKET=75
# Maximum exposure allowed per event across all open positions
RISK_MAX_EXPOSURE_PER_EVENT=100
# Maximum number of positions allowed per market
RISK_MAX_POSITIONS_PER_MARKET=2

# --- Maker / Limit Order Engine ---
# Resting order lifetime before auto-cancel
LIMIT_ORDER_TTL_SECONDS=300
# How often the order manager should consider repricing stale maker quotes
LIMIT_ORDER_REPRICE_INTERVAL_SECONDS=45
# Minimum price increment for maker quotes
LIMIT_ORDER_TICK_SIZE=0.01
# Offset from midpoint toward the bid/ask side when quoting inside the spread
LIMIT_ORDER_SPREAD_OFFSET=0.005
# Minimum expected edge per share after maker placement
LIMIT_ORDER_MIN_EDGE_AFTER_FEES=0.01
# Age threshold before an out-of-date quote is marked stale
LIMIT_ORDER_STALE_AFTER_SECONDS=120
# Reprice trigger: mark stale if market moves away by more than this many dollars
LIMIT_ORDER_STALE_PRICE_DELTA=0.02

# --- Nexus Rate Limiting ---
# Maximum Nexus research API calls allowed per rate-limit window
NEXUS_RATE_LIMIT_CALLS=20
# Window duration for Nexus rate limiting in seconds (1800 = 30 minutes)
NEXUS_RATE_LIMIT_WINDOW_SECONDS=1800
# Minutes to wait after a Nexus error before retrying research calls; cooldown auto-resets after this interval
NEXUS_COOLDOWN_RESET_MINUTES=5
# Estimated all-in cost of a single Nexus research call, used by the Python-side cost gate
NEXUS_ESTIMATED_CALL_COST_USD=0.05

# --- Kalshi ---
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=/path/to/kalshi_private_key.key
KALSHI_ENABLED=false
KALSHI_TRADE_ENABLED=false
